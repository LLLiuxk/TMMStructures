{
    "num_samples": 25000,
    "random_seed": 42,
    "sampling_mode": "random",
    "output_dir": "Output/dataset/batch_1",
    "node_position_range": [
        0.1,
        0.9
    ],
    "node_position_step": 0.1,
    "node_width_range": [
        0.1,
        0.3
    ],
    "node_width_step": 0.02,
    "nodes_per_edge_range": [
        1,
        2
    ],
    "max_node_degree": 4,
    "sparsity_range": [
        0.3,
        0.8
    ],
    "allowed_connection_types": [
        "straight_line",
        "bezier_curve",
        "circular_arc",
        "tapered_line"
    ]
}